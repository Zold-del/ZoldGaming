# Fichiers et dossiers à ignorer dans le dépôt Git

# Fichiers système
.DS_Store
Thumbs.db
desktop.ini

# Dossiers et fichiers liés à l'environnement de développement
node_modules/
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Fichiers de build/compilation
dist/
build/
*.min.js
*.min.css

# Fichiers de configuration locaux
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Fichiers de log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Fichiers temporaires
*.tmp
*.temp
.cache/

# Fichiers spécifiques au projet
.github/workflows/
